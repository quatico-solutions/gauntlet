# Copy this file to .env and fill in the values you need.
# `docker compose up` reads .env automatically.

# At least one of these is required (whichever provider you run against).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Path to the project you want Gauntlet to test. Compose mounts
# $TARGET_PROJECT into the container as /project; Gauntlet writes its
# state under /project/.gauntlet/. Leave unset (or set to ".") for
# Gauntlet-on-Gauntlet.
# TARGET_PROJECT=/Users/you/Code/my-app

# Optional overrides.
# Host+container port for the Gauntlet server. Set this if you're running
# multiple Gauntlets side-by-side (e.g. green on 4401, blue on 4400).
# GAUNTLET_PORT=4400
# GAUNTLET_AGENT_MODEL=claude-sonnet-4-6
# GAUNTLET_FANOUT_MODEL=claude-sonnet-4-6

# Maximum time (ms) `gauntlet serve` waits for in-flight runs to complete
# after receiving SIGTERM/SIGINT/SIGHUP before forcing exit. Set higher
# (e.g. 60000) if your typical run is longer than 10s and you want clean
# shutdown to wait for runs to finish naturally.
# GAUNTLET_SHUTDOWN_GRACE_MS=10000
