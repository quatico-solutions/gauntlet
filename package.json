{
  "name": "gauntlet",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "gauntlet": "src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ui": "tsc -p ui/tsconfig.json --noEmit",
    "build:ui": "cd ui && bun run build",
    "test": "bun test",
    "check": "bun run typecheck && bun run typecheck:ui && bun run build:ui && bun run test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.5",
    "bun-types": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "hono": "^4.12.5",
    "openai": "^6.27.0"
  }
}
